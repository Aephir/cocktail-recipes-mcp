# Required
COCKTAIL_API_BASE_URL=http://cocktail-app:3000
COCKTAIL_API_USERNAME=admin
COCKTAIL_API_PASSWORD=change-me

# Optional
COCKTAIL_API_LOGIN_PATH=/api/auth/login
COCKTAIL_API_TIMEOUT_SECONDS=15
COCKTAIL_API_MAX_RETRIES=3
COCKTAIL_API_RETRY_BACKOFF_SECONDS=0.5
MCP_OPERATION_LOG_SIZE=200
MCP_SERVER_NAME=cocktail-recipes-mcp
MCP_SERVER_VERSION=0.1.0

# MCP transport: stdio for local process use, streamable-http for remote clients.
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# Public HTTPS origin for remote OAuth/OIDC discovery and token audience.
PUBLIC_BASE_URL=https://cocktail-mcp.example.com

# Embedded OAuth login for the consent screen.
AUTH_USERNAME=connector-admin
AUTH_PASSWORD=change-me

# Embedded OAuth token lifetimes and persisted state.
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
OAUTH_AUTHORIZATION_CODE_TTL_SECONDS=600
OAUTH_STORAGE_DIR=/data/oauth
OAUTH_JWT_KEY_PATH=/data/oauth/jwt_signing_key.pem
# Optional host path for persisted OAuth state (useful in Portainer stacks).
OAUTH_STORAGE_HOST_DIR=/mnt/storage_1/docker/cocktail-recipes-mcp/oauth

# Optional comma-separated redirect URI prefix allowlist for dynamic registration.
OAUTH_CLIENT_REDIRECT_ALLOWLIST=

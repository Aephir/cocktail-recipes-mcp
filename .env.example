# Required
COCKTAIL_API_BASE_URL=http://cocktail-app:3000
COCKTAIL_API_USERNAME=admin
COCKTAIL_API_PASSWORD=change-me

# Optional
COCKTAIL_API_LOGIN_PATH=/api/auth/login
COCKTAIL_API_TIMEOUT_SECONDS=15
COCKTAIL_API_MAX_RETRIES=3
COCKTAIL_API_RETRY_BACKOFF_SECONDS=0.5
MCP_OPERATION_LOG_SIZE=200
MCP_SERVER_NAME=cocktail-recipes-mcp
MCP_SERVER_VERSION=0.1.0

# MCP transport: stdio for local process use, streamable-http for remote clients.
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# Optional endpoint protection for streamable-http.
# Option A (recommended for Claude custom connector): Basic Auth.
MCP_HTTP_BASIC_USERNAME=
MCP_HTTP_BASIC_PASSWORD=

# Option B: Bearer token.
MCP_HTTP_BEARER_TOKEN=

# Required
COCKTAIL_API_BASE_URL=http://cocktail-app:3000
COCKTAIL_API_USERNAME=admin
COCKTAIL_API_PASSWORD=change-me

# Optional
COCKTAIL_API_LOGIN_PATH=/api/auth/login
COCKTAIL_API_TIMEOUT_SECONDS=15
COCKTAIL_API_MAX_RETRIES=3
COCKTAIL_API_RETRY_BACKOFF_SECONDS=0.5
MCP_OPERATION_LOG_SIZE=200
MCP_SERVER_NAME=cocktail-recipes-mcp
MCP_SERVER_VERSION=0.1.0
